DOKP_BIND_ADDR=127.0.0.1:8080
DOKP_DATABASE_PATH=./data/dokp.sqlite3
DOKP_BLOB_DIR=./data/blobs
DOKP_POLL_SECONDS=300

DOKP_SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
DOKP_SLACK_CHANNEL_IDS=C01234567,C08999999

# Option 1: use an already-issued access token for short-lived checks
DOKP_GOOGLE_ACCESS_TOKEN=

# Option 2: let the server refresh tokens automatically
DOKP_GOOGLE_CLIENT_ID=
DOKP_GOOGLE_CLIENT_SECRET=
DOKP_GOOGLE_REFRESH_TOKEN=

DOKP_GEMINI_API_KEY=
DOKP_GEMINI_MODEL=gemini-2.5-flash

DOKP_GOOGLE_PRESENTATION_IDS=your-presentation-id

DOKP_NOTION_TOKEN=
DOKP_NOTION_DATABASE_ID=